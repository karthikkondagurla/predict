# ==========================================
# FRONTEND & BACKEND (Supabase Config)
# ==========================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# The URL where your backend API will be hosted
# Local development: http://localhost:3001
# Production (e.g., Render/Railway): https://your-backend.onrender.com
VITE_API_URL=http://localhost:3001


# ==========================================
# BACKEND SERVICES (Node.js Server)
# ==========================================
# Redis Configuration
# Local development: redis://localhost:6379
# Production (Upstash/Render): rediss://default:password@hostname:port
REDIS_URL=redis://localhost:6379

# --- API KEY ROTATION ---
# Provide multiple API keys separated by commas to automatically bypass daily limits.
# The server will automatically rotate to the next key if one is exhausted.

# CricAPI Keys (Supports multiple keys, no spaces after commas)
CRICAPI_KEYS=your_cricapi_key_1,your_cricapi_key_2,your_cricapi_key_3,your_cricapi_key_4

# Gemini AI Keys (Supports multiple keys, no spaces after commas)
GEMINI_KEYS=your_gemini_key_1,your_gemini_key_2
